<Window x:Class="UEClassCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UEClassCreator.ViewModels"
        Title="UE Class Creator"
        Height="800" Width="1200" MinHeight="500" MinWidth="800"
        Background="{StaticResource BrushBackground}"
        FontFamily="Segoe UI" FontSize="13"
        Loaded="Window_Loaded">

    <DockPanel>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusMessage}" HorizontalAlignment="Left"/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <ProgressBar Width="160" Height="10" Margin="0 0 8 0"
                                 Minimum="0" Maximum="{Binding ScanTotal}"
                                 Value="{Binding ScanProgress}"
                                 IsIndeterminate="{Binding IsBusy}"
                                 Background="#005A9E" Foreground="White"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main layout: left panel | splitter | right panel -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290" MinWidth="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════ LEFT PANEL ═══════════════════════════════ -->
            <DockPanel Grid.Column="0" Background="{StaticResource BrushPanel}">

                <!-- Engine picker -->
                <Border DockPanel.Dock="Top" Padding="10 8" BorderBrush="{StaticResource BrushSeparator}" BorderThickness="0 0 0 1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="↺ Rescan"
                                Padding="8 4" Margin="6 0 0 0"
                                ToolTip="Rescan all headers for the selected project"
                                Command="{Binding RescanCommand}"/>
                        <Button DockPanel.Dock="Right"
                                Content="+ Project"
                                Padding="8 4" Margin="6 0 0 0"
                                ToolTip="Add an Unreal project"
                                Command="{Binding AddProjectCommand}"/>
                        <ComboBox ItemsSource="{Binding AvailableProjects}"
                                  SelectedItem="{Binding SelectedProject}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0 2">
                                        <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ProjectDirectory}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextSecondary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </DockPanel>
                </Border>

                <!-- Company Name -->
                <Border DockPanel.Dock="Top" Padding="8 6" BorderBrush="{StaticResource BrushSeparator}" BorderThickness="0 0 0 1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="Company:" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0 0 6 0"/>
                        <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>
                </Border>

                <!-- Search box -->
                <Border DockPanel.Dock="Top" Padding="8 6" BorderBrush="{StaticResource BrushSeparator}" BorderThickness="0 0 0 1">
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="SearchBox_KeyDown"/>
                        <TextBlock Text="Search classes…"
                                   Foreground="{StaticResource BrushTextDisabled}"
                                   Margin="8 0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- UObject filter -->
                <Border DockPanel.Dock="Top" Padding="8 5" BorderBrush="{StaticResource BrushSeparator}" BorderThickness="0 0 0 1">
                    <CheckBox Content="UObject descendants only" IsChecked="{Binding FilterUObjectOnly}"/>
                </Border>

                <!-- Results list -->
                <ListBox x:Name="ResultsList"
                         ItemsSource="{Binding FilteredResults}"
                         SelectedItem="{Binding SelectedClass}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.IsDeferredScrollingEnabled="False">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding ClassName}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ParentClass, StringFormat=': {0}'}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ParentClass}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BrushSeparator}"/>

            <!-- ═══════════════════════════════ RIGHT PANEL ══════════════════════════════ -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BrushBackground}">
                <StackPanel Margin="24 20">

                    <!-- Empty state -->
                    <TextBlock Text="Select a class from the list to get started."
                               Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="14" Margin="0 40 0 0" HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClassDetail}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Class detail (visible when a class is selected) -->
                    <StackPanel DataContext="{Binding ClassDetail}">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Ancestry breadcrumb -->
                        <ItemsControl ItemsSource="{Binding AncestryChain}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="{Binding ClassName}"
                                                Style="{StaticResource LinkButton}"
                                                Command="{Binding DataContext.ClassDetail.SelectAncestorCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text=" › " Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Selected class name -->
                        <TextBlock Text="{Binding Entry.ClassName}"
                                   FontSize="22" FontWeight="Bold"
                                   Margin="0 4 0 2"/>
                        <TextBlock Text="{Binding Entry.ModuleName, StringFormat='Module: {0}'}"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontSize="11" Margin="0 0 0 12"/>

                        <Separator/>

                        <!-- Direct subclasses -->
                        <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Direct Subclasses ({0})">
                                    <Binding Path="TotalSubclassCount"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Text="None"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   FontStyle="Italic">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TotalSubclassCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding VisibleSubclasses}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding ClassName}"
                                            Margin="0 2 12 2"
                                            Style="{StaticResource LinkButton}"
                                            Command="{Binding DataContext.ClassDetail.SelectSubclassCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Show all button -->
                        <Button Margin="0 6 0 0"
                                Padding="10 3"
                                HorizontalAlignment="Left"
                                Visibility="{Binding DataContext.ClassDetail.HasMoreSubclasses,
                                             RelativeSource={RelativeSource AncestorType=Window},
                                             Converter={StaticResource BoolToVis}}"
                                Content="{Binding DataContext.ClassDetail.HiddenCount,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                ContentStringFormat="Show {0} more…"
                                Command="{Binding DataContext.ClassDetail.ShowAllSubclassesCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"/>

                        <Separator Margin="0 12"/>

                        <!-- Generation form -->
                        <TextBlock Text="New Class" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Parent class (read-only display) -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Parent Class"
                                       VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Entry.ClassName}"
                                       VerticalAlignment="Center" FontWeight="SemiBold"
                                       DataContext="{Binding DataContext.ClassDetail,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"/>

                            <!-- Class name -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Class Name"
                                       VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ClassNameBox"
                                     Text="{Binding DataContext.NewClassName, UpdateSourceTrigger=PropertyChanged,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>

                            <!-- Description -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Description"
                                       VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Text="{Binding DataContext.Description, UpdateSourceTrigger=PropertyChanged,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>

                            <!-- Output path -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Output Path"
                                       VerticalAlignment="Center" Foreground="{StaticResource BrushTextSecondary}"/>
                            <DockPanel Grid.Row="6" Grid.Column="1">
                                <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="6 0 0 0"
                                        Command="{Binding DataContext.BrowseOutputPathCommand,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
                                <TextBox Text="{Binding DataContext.OutputPath, UpdateSourceTrigger=PropertyChanged,
                                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </DockPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0 16 0 0">
                            <Button Content="Create Class"
                                    Padding="20 8"
                                    Style="{StaticResource AccentButton}"
                                    Command="{Binding DataContext.CreateClassCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <CheckBox Content="Open in Explorer"
                                      Margin="14 0 0 0"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding DataContext.OpenInExplorerAfterCreate,
                                                  RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</Window>
